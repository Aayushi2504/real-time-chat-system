# Dev: leave empty to use Vite proxy (same origin /api and /socket.io)
VITE_API_URL=
VITE_SOCKET_URL=
VITE_PROXY_TARGET=http://localhost:4000

# Production static build (e.g. Docker exposing frontend on :3000, API on :4000)
# VITE_API_URL=http://localhost:4000
# VITE_SOCKET_URL=http://localhost:4000
