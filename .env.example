# Root / Docker Compose — copy to .env in this folder for compose variable substitution
POSTGRES_USER=chat
POSTGRES_PASSWORD=chatsecret
POSTGRES_DB=chatdb
DATABASE_URL=postgresql://chat:chatsecret@postgres:5432/chatdb?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:5173
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
# Queue: local (database) | sqs (scaffold / optional AWS)
QUEUE_PROVIDER=local
# SQS (optional — only when QUEUE_PROVIDER=sqs and AWS configured)
# AWS_REGION=us-east-1
# SQS_QUEUE_URL=
# SQS_DLQ_URL=
VISIBILITY_TIMEOUT_MS=30000
MAX_QUEUE_RETRIES=5
WORKER_POLL_INTERVAL_MS=2000
LOG_LEVEL=info
